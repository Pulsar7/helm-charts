{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "replicaCount": {"type": "integer", "minimum": 1},

    "containers": {
        "type": "object",
        "properties": {
            "ntfy": {
                "type": "object",
                "properties": {
                    "image": {
                        "type": "object",
                        "properties": {
                            "repository": {"type": "string"},
                            "tag": {"type": "string"},
                            "pullPolicy": {"type": "string"}
                        }
                    },
                    "resources": {"type": "object"},
                    "service": {
                        "type": "object",
                        "properties": {
                            "type": {"type": "string"},
                            "ports": {"type": "array"}
                        }
                    },
                    "additionalVolumeMounts": {"type": "object"},
                    "additionalEnv": {"type": "object"},
                    "additionalArgs": {"type": "object"},
                    "probes": {
                        "type": "object",
                        "properties": {
                            "livenessProbe": {
                                "type": "object",
                                "properties": {
                                    "enabled": {"type": "boolean"},
                                    "initialDelaySeconds": {"type": "integer", "minimum": 0},
                                    "periodSeconds": {"type": "integer", "minimum": 0},
                                    "timeoutSeconds": {"type": "integer", "minimum": 0},
                                    "failureThreshold": {"type": "integer", "minimum": 0},
                                    "successThreshold": {"type": "integer", "minimum": 0}
                                }
                            },
                            "readinessProbe": {
                                "type": "object",
                                "properties": {
                                    "enabled": {"type": "boolean"},
                                    "initialDelaySeconds": {"type": "integer", "minimum": 0},
                                    "periodSeconds": {"type": "integer", "minimum": 0},
                                    "timeoutSeconds": {"type": "integer", "minimum": 0},
                                    "failureThreshold": {"type": "integer", "minimum": 0},
                                    "successThreshold": {"type": "integer", "minimum": 0}
                                }
                            }
                        }
                    }
                }
            }
        }
    },

    "authentication": {
        "type": "object",
        "properties": {
            "authTokens": {
                "type": "object",
                "properties": {
                    "existingSecretName": {"type": "string"},
                    "secretKey": {"type": "string"}
                }
            },
            "authUsers": {
                "type": "object",
                "properties": {
                    "existingSecretName": {"type": "string"},
                    "secretKey": {"type": "string"}
                }
            },
            "authAccess": {
                "type": "object",
                "properties": {
                    "existingSecretName": {"type": "string"},
                    "secretKey": {"type": "string"}
                }
            }
        }
    },

    "persistence": {
        "type": "object",
        "properties": {
            "enabled": {"type": "boolean"},
            "createNewPVC": {"type": "boolean"},
            "storageClassName": {"type": "string"},
            "claimName": {"type": "string"},
            "accessModes": {"type": "array"},
            "storageRequest": {"type": "string"}
        }
    },

    "configFiles": {
        "type": "object",
        "properties": {
            "serverYAML": {
                "type": "object",
                "properties": {
                    "useOwnConfigFileContent": {"type": "boolean"},
                    "ownConfigFileContent": {"type": "string"},
                    "dynamicValues": {
                        "type": "object",
                        "properties": {
                            "additionalConfig": {"type": "object"},
                            "behindProxy": {"type": "boolean"},
                            "proxyForwardedHeader": {"type": "string"},
                            "proxyTrustedHosts": {"type": "string"},
                            "baseURL": {"type": "string"},
                            "attachments": {
                                "type": "object",
                                "properties": {
                                    "enabled": {"type": "boolean"},
                                    "cacheDir": {"type": "string"},
                                    "totalSizeLimit": {"type": "string"},
                                    "fileSizeLimit": {"type": "string"},
                                    "expiryDuration": {"type": "string"}
                                }
                            },
                            "rateLimits": {
                                "type": "object",
                                "properties": {
                                    "visitorSubscriberRateLimiting": {"type": "boolean"},
                                    "messageSizeLimit": {"type": "string"},
                                    "messageDelayLimit": {"type": "string"},
                                    "globalTopicLimit": {"type": "integer", "minimum": 0},
                                    "visitorSubscriptionLimit": {"type": "integer", "minimum": 0},
                                    "visitorRequestLimitBurst": {"type": "integer", "minimum": 0},
                                    "visitorRequestLimitReplenish": {"type": "string"},
                                    "visitorRequestLimitExemptHosts": {"type": "string"},
                                    "visitorMessageDailyLimit": {"type": "integer", "minimum": 0},
                                    "visitorAttachmentTotalSizeLimit": {"type": "string"},
                                    "visitorAttachmentDailyBandwidthLimit": {"type": "string"}
                                }
                            },
                            "authFile": {"type": "string"},
                            "authDefaultAccess": {"type": "string"},
                            "authUsers":  {"type": "array"},
                            "authAccess": {"type": "array"},
                            "authTokens": {"type": "array"},
                            "cacheFile": {"type": "string"},
                            "cacheDuration": {"type": "string"},
                            "cacheBatchSize": {"type": "integer", "minimum": 0},
                            "cacheBatchTimeout": {"type": "string"},
                            "cacheStartupQueries": {"type": "string"},
                            "managerInterval": {"type": "string"},
                            "disallowedTopics": {"type": "array"},
                            "webRoot": {"type": "string"},
                            "enableSignup": {"type": "boolean"},
                            "requireLogin": {"type": "boolean"},
                            "enableLogin": {"type": "boolean"},
                            "enableReservations": {"type": "boolean"},
                            "enableMetrics": {"type": "boolean"},
                            "logLevel": {"type": "string"},
                            "logLevelOverrides": {"type": "array"},
                            "logFormat": {"type": "string", "enum": ["text", "json"]},
                            "logFile": {"type": "string"}
                        }
                    }
                }
            }
        }
    },

    "ingressRoute": {
        "type": "object",
        "properties": {
            "enabled": {"type": "boolean"},
            "entryPoints": {"type": "array"},
            "certResolver": {"type": "string"},
            "host": {"type": "string"}
        }
    }
  },

  "required": [
    "replicaCount",
    "containers",
    "persistence",
    "authentication",
    "configFiles",
    "ingressRoute"
  ],

  "title": "Values",
  "type": "object"
}