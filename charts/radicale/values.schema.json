{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "replicaCount": {"type": "integer", "minimum": 1},

    "containers": {
        "type": "object",
        "properties": {
            "radicale": {
                "type": "object",
                "properties": {
                    "image": {
                        "type": "object",
                        "properties": {
                            "repository": {"type": "string"},
                            "tag": {"type": "string"},
                            "pullPolicy": {"type": "string"}
                        }
                    },
                    "resources": {"type": "object"},
                    "service": {
                        "type": "object",
                        "properties": {
                            "type": {"type": "string"},
                            "ports": {"type": "array"}
                        }
                    },
                    "additionalVolumeMounts": {"type": "object"},
                    "environmentVariables": {"type": "array"},
                    "probes": {
                        "type": "object",
                        "properties": {
                            "livenessProbe": {
                                "type": "object",
                                "properties": {
                                    "enabled": {"type": "boolean"},
                                    "initialDelaySeconds": {"type": "integer", "minimum": 0},
                                    "periodSeconds": {"type": "integer", "minimum": 0},
                                    "timeoutSeconds": {"type": "integer", "minimum": 0},
                                    "failureThreshold": {"type": "integer", "minimum": 0},
                                    "successThreshold": {"type": "integer", "minimum": 0}
                                }
                            },
                            "readinessProbe": {
                                "type": "object",
                                "properties": {
                                    "enabled": {"type": "boolean"},
                                    "initialDelaySeconds": {"type": "integer", "minimum": 0},
                                    "periodSeconds": {"type": "integer", "minimum": 0},
                                    "timeoutSeconds": {"type": "integer", "minimum": 0},
                                    "failureThreshold": {"type": "integer", "minimum": 0},
                                    "successThreshold": {"type": "integer", "minimum": 0}
                                }
                            }
                        }
                    }
                }
            }
        }
    },

    "authentication": {
        "type": "object",
        "properties": {
            "existingSecretName": {"type": "string"},
            "secretKey": {"type": "string"}
        }
    },

    "persistence": {
        "type": "object",
        "properties": {
            "enabled": {"type": "boolean"},
            "createNewPVC": {"type": "boolean"},
            "storageClassName": {"type": "string"},
            "claimName": {"type": "string"},
            "accessModes": {"type": "array"},
            "storageRequest": {"type": "string"}
        }
    },

    "configFiles": {
        "type": "object",
        "properties": {
            "config": {
                "type": "object",
                "properties": {
                    "useOwnConfigFileContent": {"type": "boolean"},
                    "ownConfigFileContent": {"type": "string"},
                    "dynamicValues": {
                        "type": "object",
                        "properties": {
                            "serverSection": {"type": "string"},
                            "authSection": {"type": "string"},
                            "storageSection": {"type": "string"}
                        }
                    }
                }
            }
        }
    },

    "ingressRoute": {
        "type": "object",
        "properties": {
            "enabled": {"type": "boolean"},
            "entryPoints": {"type": "array"},
            "certResolver": {"type": "string"},
            "host": {"type": "string"}
        }
    },

    "middlewares": {
        "type": "array"
    }
  },

  "required": [
    "replicaCount",
    "containers",
    "persistence",
    "authentication",
    "configFiles",
    "ingressRoute",
    "middlewares"
  ],

  "title": "Values",
  "type": "object"
}