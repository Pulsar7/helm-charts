{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "replicaCount": {"type": "integer", "minimum": 1},
    "strategy": {
      "type": "object"
    },
    "podSecurityContext": {"type": "object"},
    "podAnnotations": {"type": "object"},
    "podLabels": {"type": "object"},
    "additionalVolumes": {"type": "object"},
    "nodeSelector": {"type": "object"},
    "affinity": {"type": "object"},
    "tolerations": {"type": "array"},
    "initContainers": {"type": "array"},

    "containers": {
        "type": "object",
        "properties": {
            "librefrontier": {
                "type": "object",
                "properties": {
                    "image": {
                        "type": "object",
                        "properties": {
                            "repository": {"type": "string"},
                            "tag": {"type": "string"},
                            "pullPolicy": {"type": "string"}
                        }
                    },
                    "resources": {"type": "object"},
                    "services": {
                        "type": "object",
                        "properties": {
                            "httpAPI": {
                              "type": "object",
                              "properties": {
                                "type": {"type": "string", "enum": ["ClusterIP", "NodePort"]},
                                "containerPort": {"type": "integer", "minimum": 1},
                                "port": {"type": "integer", "minimum": 1}
                              }
                            },
                            "webUI": {
                              "type": "object",
                              "properties": {
                                "enabled": {"type": "boolean"},
                                "type": {"type": "string", "enum": ["ClusterIP", "NodePort"]},
                                "containerPort": {"type": "integer", "minimum": 1},
                                "port": {"type": "integer", "minimum": 1}
                            }
                          }
                        }
                    },
                    "additionalVolumeMounts": {"type": "object"},
                    "additionalEnv": {"type": "object"},
                    "additionalArgs": {"type": "object"},
                    "probes": {
                        "type": "object",
                        "properties": {
                            "livenessProbe": {
                                "type": "object",
                                "properties": {
                                    "enabled": {"type": "boolean"},
                                    "initialDelaySeconds": {"type": "integer", "minimum": 0},
                                    "periodSeconds": {"type": "integer", "minimum": 0},
                                    "timeoutSeconds": {"type": "integer", "minimum": 0},
                                    "failureThreshold": {"type": "integer", "minimum": 0},
                                    "successThreshold": {"type": "integer", "minimum": 0}
                                }
                            },
                            "readinessProbe": {
                                "type": "object",
                                "properties": {
                                    "enabled": {"type": "boolean"},
                                    "initialDelaySeconds": {"type": "integer", "minimum": 0},
                                    "periodSeconds": {"type": "integer", "minimum": 0},
                                    "timeoutSeconds": {"type": "integer", "minimum": 0},
                                    "failureThreshold": {"type": "integer", "minimum": 0},
                                    "successThreshold": {"type": "integer", "minimum": 0}
                                }
                            }
                        }
                    }
                }
            }
        }
    },

    "librefrontierConfig": {
      "type": "object",
      "properties": {
        "ginMode": {"type": "string", "enum": ["release", "debug"]},
        "LFAPIBaseURL": {"type": "string"},
        "databaseConnectionString": {
          "type": "object",
          "properties": {
            "secretName": {"type": "string"},
            "existingSecret": {"type": "boolean"},
            "stringData": {"type": "string"}
          }
        }
      }
    },

    "httpAPIIngressRoute": {
        "type": "object",
        "properties": {
            "enabled": {"type": "boolean"},
            "entryPoints": {"type": "array"},
            "host": {"type": "string"}
        }
    },
    "webUIIngressRoute": {
        "type": "object",
        "properties": {
            "enabled": {"type": "boolean"},
            "entryPoints": {"type": "array"},
            "certResolver": {"type": "string"},
            "host": {"type": "string"}
        }
    }
  },

  "required": [
    "replicaCount",
    "initContainers",
    "containers",
    "httpAPIIngressRoute",
    "webUIIngressRoute"
  ],

  "title": "Values",
  "type": "object"
}
