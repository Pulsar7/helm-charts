{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "replicaCount": {"type": "integer", "minimum": 1},

    "initContainers": {"type": "array"},

    "containers": {
        "type": "object",
        "properties": {
            "librefrontier": {
                "type": "object",
                "properties": {
                    "image": {
                        "type": "object",
                        "properties": {
                            "repository": {"type": "string"},
                            "tag": {"type": "string"},
                            "pullPolicy": {"type": "string"}
                        }
                    },
                    "resources": {"type": "object"},
                    "service": {
                        "type": "object",
                        "properties": {
                            "type": {"type": "string"},
                            "ports": {"type": "array"}
                        }
                    },
                    "config": {
                        "type": "object",
                        "properties": {
                            "ginMode": {"type": "string", "enum": ["release", "debug"]},
                            "LFAPIBaseURL": {"type": "string"},
                            "lfDatabaseConnectionString": {"type": "string"}
                        }
                    },
                    "additionalVolumeMounts": {"type": "object"},
                    "additionalEnv": {"type": "object"},
                    "additionalArgs": {"type": "object"},
                    "probes": {
                        "type": "object",
                        "properties": {
                            "livenessProbe": {
                                "type": "object",
                                "properties": {
                                    "enabled": {"type": "boolean"},
                                    "initialDelaySeconds": {"type": "integer", "minimum": 0},
                                    "periodSeconds": {"type": "integer", "minimum": 0},
                                    "timeoutSeconds": {"type": "integer", "minimum": 0},
                                    "failureThreshold": {"type": "integer", "minimum": 0},
                                    "successThreshold": {"type": "integer", "minimum": 0}
                                }
                            },
                            "readinessProbe": {
                                "type": "object",
                                "properties": {
                                    "enabled": {"type": "boolean"},
                                    "initialDelaySeconds": {"type": "integer", "minimum": 0},
                                    "periodSeconds": {"type": "integer", "minimum": 0},
                                    "timeoutSeconds": {"type": "integer", "minimum": 0},
                                    "failureThreshold": {"type": "integer", "minimum": 0},
                                    "successThreshold": {"type": "integer", "minimum": 0}
                                }
                            }
                        }
                    }
                }
            }
        }
    },

    "APIingressRoute": {
        "type": "object",
        "properties": {
            "enabled": {"type": "boolean"},
            "entryPoints": {"type": "array"},
            "host": {"type": "string"}
        }
    },
    "webUIingressRoute": {
        "type": "object",
        "properties": {
            "enabled": {"type": "boolean"},
            "entryPoints": {"type": "array"},
            "certResolver": {"type": "string"},
            "host": {"type": "string"}
        }
    }
  },

  "required": [
    "replicaCount",
    "initContainers",
    "containers",
    "APIingressRoute",
    "webUIingressRoute"
  ],

  "title": "Values",
  "type": "object"
}